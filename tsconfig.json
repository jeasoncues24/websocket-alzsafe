{
    "compilerOptions": {
      "target": "ES2020",        /* Especifica la versión de ECMAScript de destino. */
      "module": "CommonJS",      /* Especifica el sistema de módulos a usar. */
      "outDir": "./dist",        /* Redirige la salida a este directorio. */
      "strict": true,            /* Habilita todas las comprobaciones de tipo estrictas. */
      "esModuleInterop": true,   /* Emite código adicional para admitir la importación CommonJS/AMD/UMD. */
      "skipLibCheck": true,       /* Omite la verificación de tipo de todos los archivos de declaración (*.d.ts). */
      "forceConsistentCasingInFileNames": true /* Prohíbe referencias no coincidentes a la capitalización de archivos. */
    },
    "include": [
      "src/**/*"                /* Incluye todos los archivos TypeScript dentro de la carpeta 'src'. */
    ],
    "exclude": [
      "node_modules"             /* Excluye la carpeta 'node_modules'. */
    ]
  }