# ==============================================================
# Frontend — Variables de entorno
# Archivo plantilla versionado. Cópialo como .env.local y ajusta
# los valores según tu entorno.
# ==============================================================

# URL pública del backend (usada por el browser en runtime).
# Debe ser accesible desde el navegador del usuario.
# Requerida — la app lanza error si no está definida.
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL interna del backend para el proxy server-side de Next.js.
# Útil cuando el browser y el servidor Next.js usan rutas distintas.
# En local, normalmente puede ser la misma URL pública.
# Si no se define, Next.js reutiliza NEXT_PUBLIC_API_URL.
# NEXT_INTERNAL_API_URL=http://localhost:8080

# Puerto en el que corre el servidor Next.js.
# También puedes sobreescribirlo con: make dev PORT=3002
PORT=3001
