# wsapi backend (Go) - Variables de Entorno
# Copia este archivo a .env y completa los valores
# El frontend tiene su propio ejemplo en frontend/.env.example

# ============================================
# Base de Datos (MariaDB/MySQL) - REQUERIDO
# ============================================

DB_HOST=127.0.0.1       # Host de MariaDB
DB_PORT=3306            # Puerto de MariaDB
DB_NAME=wsapi           # Nombre de la base de datos
DB_USER=root            # Usuario de la base de datos
DB_PASS=                # Contraseña del usuario

# ============================================
# Aplicación
# ============================================

APP_ENV=development     # Entorno: development, production
APP_PORT=8080           # Puerto del servidor

# ============================================
# JWT
# ============================================

JWT_SECRET=change-me    # Secret usado para firmar JWT
JWT_EXPIRY=24h          # Expiración del access token
JWT_REFRESH_EXPIRY=168h # Expiración del refresh token
JWT_ISSUER=wsapi        # Emisor del token

# ============================================
# WhatsApp / Runtime
# ============================================

WHATSAPP_SQLITE_DIR=sessions/whatsappmeow # Directorio local de sesiones
WHATSAPP_BOOTSTRAP_ENABLED=true           # Rehidrata sesiones al iniciar backend
WHATSAPP_BOOTSTRAP_MAX_CONCURRENCY=4      # Concurrencia bootstrap de sesiones
WHATSAPP_BOOTSTRAP_TIMEOUT_SEC=60         # Timeout global del bootstrap en startup

# Logging WhatsApp (salida concisa en terminal + debug detallado a archivo)
WHATSAPP_DEBUG_LOG_DIR=debug_log          # Carpeta base para logs debug diarios
WHATSAPP_DEBUG_LOG_PER_ACCOUNT=true       # true = separa logs por sesion/account
WHATSAPP_DEBUG_LOG_LEVEL=DEBUG            # DEBUG, INFO, WARN, ERROR (archivo)
WHATSAPP_CONSOLE_LOG_LEVEL=INFO           # INFO, WARN, ERROR (terminal)

# ============================================
# Logging
# ============================================

LOG_LEVEL=info         # Nivel: debug, info, warn, error

# ============================================
# Notas de Uso
# ============================================
#
# Para ejecutar el servidor:
#   ./wsapi
#
# Para ejecutar migraciones:
#   ./wsapi migrate status  - Ver estado de migraciones
#   ./wsapi migrate up     - Aplicar migraciones pendientes
#   ./wsapi migrate down  - Revertir última migración
#
# Credenciales por defecto:
#   Admin: admin / admin123
#
